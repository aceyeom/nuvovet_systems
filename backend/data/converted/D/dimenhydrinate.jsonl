  "effects_and_mechanisms": {
    "common_mechanism": "H1 히스타민 수용체 차단, 항콜린 작용, CNS 억제, 국소마취 효과를 가짐. 디펜히드라민과 8-클로로테오필린의 복합체로, 주요 약리 작용은 디펜히드라민 부분에 기인함. 전정 자극을 억제하며, 항콜린 작용이 전정계 및 망상계의 아세틸콜린 자극을 차단하는 데 관여할 수 있음.",
    "common_extra_effects": [
      "CNS 억제 (기면, 졸음)",
      "항콜린 효과 (구강 건조, 요저류)",
      "설사",
      "구토",
      "식욕부진",
      "역설적 흥분 또는 초조 (특히 고양이)"
    ],
    "dog_mechanism": "전정 자극 억제를 통한 항구토 효과. 항콜린 작용이 전정계 및 망상계의 아세틸콜린 자극 차단에 기여. 장기 사용 시 CNS 억제 효과 및 항구토 효과에 내성이 생길 수 있음.",
    "dog_extra_effects": [
      "CNS 억제 (기면, 졸음)",
      "항콜린 효과",
      "GI 증상 (설사, 구토, 식욕부진)"
    ],
    "cat_mechanism": "고양이에서 히스타민은 구토의 중요한 매개체가 아닌 것으로 알려져 있어 효과가 제한적일 수 있음.",
    "cat_extra_effects": [
      "역설적 흥분 또는 초조",
