  "effects_and_mechanisms": {
    "common_mechanism": "글루코코르티코이드 수용체를 통한 유전자 발현 직접 조절 및 세포막·수용체에 대한 비유전체적 효과를 통해 광범위한 면역조절 및 항염증 작용을 나타냄. 염증성 프로스타글란딘 및 류코트리엔 생성 억제, B세포 및 T세포 수와 기능 감소, 세포매개 면역 및 체액성 면역 억제.",
    "common_extra_effects": [
      "백내장 형성 (포도당 또는 수정체 대사 변화)",
      "안압 상승 (섬유주 내 글루코코르티코이드 수용체 활성화)",
      "감염 위험 증가 (면역억제)",
      "상처 치유 지연 (콜라겐 분해 활성 증가)",
      "산동",
      "석회성 각막병증",
      "간병증 (전신 흡수 시)",
      "내인성 글루코코르티코이드 생성 억제 (전신 흡수 시)",
      "국소 탈모 (전신 흡수 시)"
    ],
    "dog_mechanism": "점안 투여 후 정상 개의 전안부에서 측정 가능한 덱사메타손 농도 확인됨.",
    "dog_extra_effects": [
      "안압 상승 (만성 사용 시, 대부분 투여 중단 시 가역적)",
      "전신 흡수로 인한 부작용 가능성"
    ],
    "cat_mechanism": "점안 투여 후 정상 고양이의 전안부에서 측정 가능한 덱사메타손 농도 확인됨.",
    "cat_extra_effects": [
      "녹내장 고양이에서 임상적으로 유의한 안압 상승 가능성",
      "전신 흡수로 인한 부작용 가능성"
    ]
  },
  "species_notes": {
    "dog": "개에서 덱사메타손 점안제의 상대적 효능에 대한 평가는 수행되지 않았음. 덱사메타손 알코올 제형이 소듐 포스페이트 제형보다 전안부 침투력이 높으나, 프레드니솔론 아세테이트 현탁액보다는 낮음. 만성 사용 시 안압 상승이 가능하나 대부분 투여 중단 시 가역적임.",
    "cat": "고양이에서 덱사메타손 점안제의 상대적 효능에 대한 평가는 수행되지 않았음. 녹내장이 있는 고양이에서 점안 덱사메타손 투여 시 임상적으로 유의한 안압 상승이 보고되었으므로 안압 모니터링이 특히 중요함."
  },
