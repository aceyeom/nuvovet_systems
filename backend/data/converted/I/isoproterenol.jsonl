  "effects_and_mechanisms": {
    "common_mechanism": "비선택적 베타-1 및 베타-2 아드레날린 수용체 작용제. 사이클릭 AMP 생성 자극을 통해 심근 수축력 및 심박수 증가, 기관지 평활근 이완, 말초 혈관 확장을 유발함. 히스타민 및 SRS-A의 항원 매개 방출을 억제함.",
    "common_extra_effects": [
      "빈맥",
      "저혈압",
      "불안",
      "진전",
      "흥분성",
      "두통",
      "쇠약",
      "구토",
      "부정맥 유발",
      "심근 산소 요구량 증가",
      "관상동맥 관류 감소",
      "고용량 시 심근 괴사"
    ],
    "dog_mechanism": "베타-1 및 베타-2 수용체 자극을 통해 심박수 및 심박출량 증가, 기관지 확장, 말초 혈관 저항 감소. 저산소 상태의 개에서 치사량은 10–50 µg/kg IV.",
    "dog_extra_effects": [
      "빈맥",
      "저혈압",
      "부정맥",
      "심근 괴사 (고용량)"
    ],
    "cat_mechanism": null,
    "cat_extra_effects": []
  },
  "species_notes": {
    "dog": "이소프로테레놀은 수의학에서 드물게 사용됨. 도파민이나 도부타민보다 부정맥 유발성이 높아 심부전 치료에는 거의 사용되지 않음. 완전 방실 차단, 동성 서맥, 동방정지 등의 서맥성 부정맥 치료에 IV CRI로 사용 가능. 심혈관 상태(심박수, 리듬, 혈압, 중심정맥압, 심박출량), 호흡수, 소변량, 혈가스를 면밀히 모니터링해야 함.",
    "cat": "개와 동일한 적응증 및 용량으로 사용 가능(오프라벨). 고양이 특이적 PK 데이터는 없음. 훈련된 인력에 의해 적절한 모니터링 환경에서만 사용해야 함."
  },
  "precautions": {
    "dog": {
      "status": 1,
      "evidence": "관상동맥 부전, 갑상선 기능 항진증, 신장 질환, 고혈압, 당뇨병 환자에서 주의 사용. 쇼크 시 적절한 수액 대체 요법의 대안이 아님. 임신 중 안전성 미확립."
    },
    "cat": {
      "status": 1,
      "evidence": "개와 동일한 주의사항 적용. 고양이 특이적 안전성 데이터 없음. 훈련된 인력에 의해 모니터링 환경에서만 사용."
    }
  },
  "storage_and_forms": {
    "storage": "빛을 차단하여 실온(20–25°C, 68–77°F)에서 보관. 공기, 빛, 열에 노출 시 이소프로테레놀 염이 변색됨. 분홍색 또는 갈색-분홍색으로 변색된 용액이나 침전물이 있는 용액은 사용 금지. pH 6 초과 용액과 혼합 시 즉시 사용 권장.",
    "forms": [
      "Isoproterenol HCl 주사액 0.2 mg/mL (1 mL 및 5 mL 앰플 또는 단회용 바이알)"
    ]
