  "effects_and_mechanisms": {
    "common_mechanism": "플루시토신은 진균 세포 내로 침투하여 시토신 탈아미노효소에 의해 플루오로우라실로 전환됨. 플루오로우라실은 항대사물질로 작용하여 우라실과 경쟁함으로써 피리미딘 대사, RNA 및 단백질 합성을 방해함. 이후 플루오로데옥시우리딜산으로 전환되어 티미딜산 합성 및 DNA 합성을 억제함.",
    "common_extra_effects": [
      "오심, 구토, 설사 등 위장관 장애",
      "용량 의존적 골수억제 (빈혈, 백혈구감소증, 혈소판감소증)",
      "구강 궤양",
      "간효소 상승"
    ],
    "dog_mechanism": "개 세포의 시토신 탈아미노효소 활성 여부는 불명확함. 장내 세균이 소량을 플루오로우라실로 전환할 수 있음.",
    "dog_extra_effects": [
      "피부/점막 약물 반응 (탈색소, 궤양, 삼출, 가피 형성 — 주로 음낭 및 비강 평면에 발생)",
      "치료 시작 후 10~20일 이내(최대 6주) 발생 가능",
      "골수억제",
      "간효소 상승"
    ],
    "cat_mechanism": "고양이 세포의 시토신 탈아미노효소 활성 여부는 불명확함.",
