  "effects_and_mechanisms": {
    "common_mechanism": "페노피브르산(활성형)이 퍼옥시좀 증식인자 활성화 수용체(PPAR)를 활성화하여 지단백 리파아제 농도 및 활성을 증가시킴. 이로 인해 초저밀도 지단백(VLDL) 및 중성지방의 청소율이 증가하고, LDL-콜레스테롤이 덜 동맥경화성으로 변하며 더 쉽게 제거됨. 요산의 요중 배설도 증가시킴.",
    "common_extra_effects": [
      "설사",
      "고창증(방귀)",
      "ALT 상승",
      "크레아틴키나아제(CK) 상승",
      "근병증",
      "횡문근융해증",
      "담석증",
      "췌장염",
      "간효소 증가",
      "혈청 크레아티닌 증가",
      "혈색소 감소",
      "백혈구 감소",
      "혈소판감소증",
      "무과립구증"
    ],
    "dog_mechanism": "페노피브레이트는 프로드러그로, 활성형인 페노피브르산으로 전환되어야 하나 개에서는 다른 대사산물도 생성될 수 있음. PPAR 활성화를 통해 중성지방 및 콜레스테롤 감소 효과 발휘.",
    "dog_extra_effects": [
      "설사",
      "고창증",
      "ALT 상승 (2.5배)",
      "크레아틴키나아제(CK) 상승"
    ],
    "cat_mechanism": null,
    "cat_extra_effects": []
  },
  "species_notes": {
    "dog": "개에서 페노피브레이트는 고중성지방혈증 치료에 86~100%의 정상화율을 보임. 3~4주 치료 후 중성지방 73~88% 감소, 총 콜레스테롤 10~20% 감소 보고. 나노크리스탈 정제 또는 일반 정제 사용 가능하나 제형 간 생체이용률이 다르므로 처방 시 제품 명시 필요. 설사/고창증 발생 시 일시 중단 후 저용량으로 재시작 가능. 기존 신장 질환, 담낭 질환, 간질환 환자에서 주의 또는 금기.",
    "cat": "고양이에서의 임상 경험이 매우 제한적이며 공개된 임상 연구 없음. 효능 및 안전성 미확립. 현재로서는 사용 권장 불가."
  },
  "precautions": {
    "dog": {
      "status": 1,
      "evidence": "기존 신장 질환, 담낭 질환(담낭 점액낭종 포함), 간질환 환자에서 주의 사용. 근병증 위험 모니터링 필요. 간효소 지속 상승(정상 상한치 3배 초과), 담석 발견, 근병증/근염 발생 시 투약 중단."
    },
    "cat": {
      "status": 1,
      "evidence": "고양이에서 효능 및 안전성 미확립. 임상 경험 매우 제한적."
    }
  },
