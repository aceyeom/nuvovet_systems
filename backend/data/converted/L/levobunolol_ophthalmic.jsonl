  "effects_and_mechanisms": {
    "common_mechanism": "비선택적 베타-아드레날린 수용체 차단제. 섬모체의 베타-2 수용체 차단을 통해 방수(aqueous humor) 생성을 감소시켜 안압(IOP)을 낮춤. cAMP 활성화 감소, Na+K+ATPase 억제, 홍채 및 섬모체의 혈관 작용 기전이 제안됨. 또한 글루타민 유발 세포내 칼슘 및 나트륨 증가를 억제하여 망막 허혈 손상에 대한 보호 효과 가능.",
    "common_extra_effects": [
      "점안 시 일시적 작열감",
      "점안 시 일시적 따끔거림",
      "점안 시 일시적 자극감",
      "심박수 감소 (전신 흡수 시)"
    ],
    "dog_mechanism": "국소 점안 투여 후 전신 흡수로 인해 건강한 개에서 심박수의 유의한 감소가 보고됨.",
    "dog_extra_effects": [
      "심박수 감소",
      "점안 시 일시적 자극감"
    ],
    "cat_mechanism": null,
    "cat_extra_effects": []
  },
  "species_notes": {
    "dog": "개에서 레보부놀롤 단독 사용 시 안압 감소 효과는 레보부놀롤+도르졸아미드 병용 또는 티몰롤+도르졸아미드 병용에 비해 낮다. 국소 투여 후 전신 흡수로 인한 심박수 감소가 확인되었으므로 심폐 질환이 있는 개에서는 사용을 제한해야 한다. 편측 녹내장 환자의 정상안에 예방적으로 사용할 수 있다.",
    "cat": "고양이에 대한 용량 정보가 Plumb's 모노그래프에 명시되어 있지 않다. 천식 또는 기관지 질환이 있는 고양이에서는 기관지경련 유발 가능성으로 인해 주의가 필요하다."
  },
