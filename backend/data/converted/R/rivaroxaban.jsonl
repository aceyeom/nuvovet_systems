  "genetic_sensitivity": {
    "has_genetic_risk": true,
    "affected_breeds": [],
    "gene": "ABCB1 (MDR1)",
    "evidence": "리바록사반은 P-당단백질(P-gp) 기질임. MDR1 돌연변이 품종(예: 콜리, 셰틀랜드 쉽독 등)에서 약물 노출 증가 가능성이 있으나, 수의학 문헌에서 직접적인 근거는 제한적임."
  },
  "effects_and_mechanisms": {
    "common_mechanism": "활성화 응고인자 X(FXa) 및 프로트롬비나제 활성 억제. 헤파린과 달리 보조인자 없이 직접 작용. 트롬빈에 의한 혈소판 응집을 간접적으로 억제.",
    "common_extra_effects": [
      "출혈 (가장 흔한 이상반응)",
      "오심, 구토, 설사",
      "간효소 수치 상승",
      "소양증, 발진 (드묾)"
    ],
    "dog_mechanism": "개에서 FXa의 리바록사반 친화도는 인간보다 낮음 (50% 트롬빈 생성 억제에 약 0.4 µg/mL 필요). 최대 항FXa 활성은 투여 후 2~4시간에 발생.",
    "dog_extra_effects": [
      "경미한 출혈 (비출혈, 혈토, 혈뇨, 혈변)",
      "빈혈",
      "구토"
    ],
    "cat_mechanism": "고양이에서 최대 항FXa 활성은 투여 후 2~3시간에 발생.",
    "cat_extra_effects": [
      "경미한 출혈",
      "구토"
    ]
  },
  "species_notes": {
    "dog": "개에서 리바록사반은 비분획 헤파린과 동등한 효능, 예측 가능한 약동학, 경구 투여 편의성으로 선호될 수 있음. 생체 내 응고 평가에 따르면 q12h 투여가 더 적절할 수 있음. 수의학적 사용 경험은 아직 제한적임.",
    "cat": "고양이에서 직접 FXa 억제제는 예측 가능한 약동학과 양호한 안전성 프로파일로 고려될 수 있음. 용량은 mg/kg이 아닌 마리당 고정 용량(mg/마리)으로 처방해야 함. 1.25 mg/마리 q24h는 건강한 고양이에서 12시간 미만의 항FXa 활성만 제공하므로 더 높은 용량 연구가 필요함."
  },
