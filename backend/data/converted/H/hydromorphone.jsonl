    ],
    "dog_mechanism": "뮤 오피오이드 수용체 작용을 통해 진통, 진정, 호흡 억제 유발. 이소플루란 MAC을 33~50% 감소시킴.",
    "dog_extra_effects": [
      "구토",
      "진정",
      "헐떡임(panting)",
      "발성/울음",
      "배변",
      "CNS 억제",
