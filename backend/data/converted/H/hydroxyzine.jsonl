  "effects_and_mechanisms": {
    "common_mechanism": "H1 수용체 길항제로서 히스타민 H1 수용체를 경쟁적으로 억제함. 히스타민을 불활성화하거나 방출을 막지는 않으나 세포에 대한 히스타민 작용을 차단함. 추가적으로 항콜린, 진정, 안정, 항경련, 국소마취, 경도 기관지확장, 항구토 효과를 가짐.",
    "common_extra_effects": [
      "진정/졸음",
      "역설적 흥분",
      "항콜린 효과 (구강 건조, 요저류, 변비)",
      "QT 연장",
      "주사 부위 조직 손상/괴사 (SC 투여 시)",
      "과다복용 시: 기면, 고체온, 떨림, 빈맥, 운동실조, 경련"
    ],
    "dog_mechanism": "H1 수용체 길항을 통한 항소양 및 항히스타민 효과. 활성 대사체 세티리진으로 빠르게 전환됨.",
    "dog_extra_effects": [
      "진정 (경미하고 일시적, 반복 투여 시 감소 가능)",
      "미세 급속 떨림, 전신 떨림",
      "드물게 경련",
      "역설적 흥분"
    ],
    "cat_mechanism": "H1 수용체 길항을 통한 항소양 및 항히스타민 효과.",
    "cat_extra_effects": [
