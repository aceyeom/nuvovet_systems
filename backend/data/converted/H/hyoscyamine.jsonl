  "effects_and_mechanisms": {
    "common_mechanism": "아트로핀의 좌선성 이성질체인 항콜린성 약물로, 부교감신경 절후 신경에 의해 지배되는 조직 및 콜린성 신경지배 없이 아세틸콜린에 반응하는 평활근에서 아세틸콜린을 억제함. 자율신경절에는 작용하지 않음. 용량 의존적으로 분비 감소, 위장관 및 요로 운동성 감소, 산동, 심박수 증가를 유발함.",
    "common_extra_effects": [
      "산동 (mydriasis)",
      "구강 건조 (xerostomia)",
      "변비 (constipation)",
      "요저류 (urinary retention)",
      "빈맥 (tachycardia)",
      "안구 건조 (xerophthalmia)",
      "고용량 시 CNS 억제 또는 흥분"
    ],
    "dog_mechanism": "아트로핀보다 중추 및 말초 효과가 강한 항콜린성 약물. 개에서 서맥, 방실 차단, 과민성 장 증후군 치료에 사용 가능.",
    "dog_extra_effects": [
      "산동",
      "구강 건조",
      "변비",
      "요저류",
      "빈맥",
      "안구 건조",
      "CNS 억제 또는 흥분 (고용량)"
    ],
    "cat_mechanism": null,
    "cat_extra_effects": []
  },
  "species_notes": {
    "dog": "개에서 페이스메이커 삽입이 불가능한 경우 임상 증상을 동반한 서맥 또는 방실 차단의 대안 치료제로 사용 가능. 만성 특발성 대장 질환 등 과민성 장 증후군의 단기 치료에도 유용할 수 있음. 수의학에서의 안전성 및 유효성 데이터가 제한적이므로 주의 깊은 모니터링 필요. 즉시방출형 경구 제제 기준으로 용량 설정됨.",
    "cat": "고양이에 대한 용량 데이터 없음. 안전성 및 유효성이 확립되지 않아 사용 권장하지 않음."
  },
