  "effects_and_mechanisms": {
    "common_mechanism": "H1 수용체, 알파2-아드레날린 수용체, 무스카린 수용체 길항 작용; 도파민 길항 작용(다른 페노티아진보다 약함). 구토 억제는 주로 뇌의 구토 중추 및 화학수용체 유발대(CTZ)에 대한 작용에 의함.",
    "common_extra_effects": [
      "진정",
      "항콜린 효과 (구강 건조, 변비, 요저류)",
      "역설적 CNS 자극 (과흥분, 진전, 비정상적 근육 운동, 경련)",
      "경련 역치 저하",
      "저혈압",
      "추체외로 증상",
      "주사 부위 반응"
    ],
    "dog_mechanism": "페노티아진 계열로서 H1, 알파2-아드레날린, 무스카린 수용체 길항 작용을 통해 구토 억제 및 항히스타민 효과 발휘.",
    "dog_extra_effects": [
      "진정",
      "항콜린 효과",
