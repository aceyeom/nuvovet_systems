  "effects_and_mechanisms": {
    "common_mechanism": "비경쟁적 알파-아드레날린 수용체 차단제(비선택적). 알파-1 수용체에 더 높은 친화성을 가지며, 순환하는 에피네프린 및 노르에피네프린의 알파-아드레날린 반응을 비경쟁적으로 차단. 화학적 교감신경 절제술 효과. 베타 수용체 및 부교감신경계에는 영향 없음.",
    "common_extra_effects": [
      "저혈압(hypotension)",
      "반사성 빈맥(reflex tachycardia)",
      "동공 축소(miosis)",
      "안압 상승(increased intraocular pressure)",
      "사정 억제(inhibition of ejaculation)",
      "비충혈(nasal congestion)",
      "허약/어지러움(weakness/dizziness)",
      "오심, 구토(nausea, vomiting)",
      "나트륨 저류(sodium retention)",
      "반동성 고혈압(rebound hypertension)"
    ],
    "dog_mechanism": "요도 내괄약근 긴장도 감소 및 갈색세포종 관련 고혈압 조절에 사용. 수술 전 갈색세포종 관련 고혈압 조절 시 수술 후 지속적 저혈압 유발 가능.",
    "dog_extra_effects": [
      "수술 후 지속적 저혈압(prolonged postoperative hypotension)",
      "운동실조(ataxia)",
      "실신(syncope)"
    ],
    "cat_mechanism": "요도 내괄약근 긴장도 감소 목적으로 사용. 고양이 요도 재폐색 예방에는 프라조신이 더 효과적일 수 있음.",
    "cat_extra_effects": [
      "저혈압(hypotension)",
      "빈맥(tachycardia)"
    ]
  },
  "species_notes": {
    "dog": "개에서 요도 과긴장으로 인한 기능적 요도 폐색 및 갈색세포종 관련 고혈압 조절에 허가 외 사용. 효과 발현까지 1주 이상 소요될 수 있으며, 수 주간 투여 후 효과를 판정해야 함. 갈색세포종 수술 전 사용 시 수술 후 지속적 저혈압에 대비한 수액 보충이 필요할 수 있음. 페닐프로판올아민 과다복용으로 인한 빈맥 치료에 사용된 사례 보고 있음.",
    "cat": "고양이 요도 재폐색 예방에는 프라조신이 페녹시벤자민보다 더 효과적인 것으로 보고됨. 베타네콜과 병용 시 페녹시벤자민을 2~3일 먼저 시작할 것을 권장. 고정 용량(mg/cat, mg/kg 아님)으로 투여."
  },
