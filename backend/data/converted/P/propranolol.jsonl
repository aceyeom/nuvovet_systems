  "effects_and_mechanisms": {
    "common_mechanism": "비선택적 베타-1 및 베타-2 아드레날린 수용체 차단제. 심근, 기관지, 혈관 평활근의 베타 수용체를 차단하여 심박수 감소, 방실전도 억제, 심박출량 감소, 혈압 강하 효과를 나타냄. 내인성 교감신경 유사 활성(ISA) 없음. 퀴니딘 유사 막안정화 효과 및 직접적 심근 억제 효과 보유.",
    "common_extra_effects": [
      "서맥",
      "무기력증 및 우울",
      "방실전도 장애",
      "울혈성 심부전 또는 심부전 악화",
      "저혈압",
      "실신",
      "설사",
      "저혈당",
      "기관지수축"
    ],
    "dog_mechanism": "베타-1 수용체 차단으로 우심실 과수축 제한, 베타-2 수용체 차단으로 말초 혈관 확장 억제 — 우좌 단락(예: 팔로 사징) 환자에서 유익할 수 있음.",
    "dog_extra_effects": [
      "서맥",
      "저혈압",
      "기관지수축",
      "저혈당",
      "심부전 악화"
    ],
    "cat_mechanism": "소동물에서 갑상선기능항진증 및 빈맥성 부정맥 관련 임상 증상 조절에 사용됨.",
    "cat_extra_effects": [
      "서맥",
      "기관지수축 (고양이 천식 환자에서 특히 위험)",
      "저혈압",
      "심부전 악화"
    ]
  },
  "species_notes": {
    "dog": "개에서 주로 빈맥성 부정맥, 우좌 단락(팔로 사징), 갑상선기능항진증, 갈색세포종, 베타-2 작용제 독성 치료에 사용됨. 경구 생체이용률이 낮고 반감기가 짧아 아테놀롤 등 심장선택적 베타차단제로 대체되는 경우가 많음. 만성 투여 후 갑작스러운 중단은 피하고 점진적으로 감량할 것.",
    "cat": "고양이에서 갑상선기능항진증 관련 빈맥 및 부정맥 조절에 사용될 수 있으나, 고양이는 기관지수축에 민감하므로 기관지경련성 폐질환(고양이 천식) 환자에서는 절대 금기. 페럿에서는 비대성 심근병증의 보조 치료로 사용된 보고가 있음."
  },
