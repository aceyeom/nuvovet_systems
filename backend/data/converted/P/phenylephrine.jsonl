  "effects_and_mechanisms": {
    "common_mechanism": "알파-1 아드레날린 수용체 작용제로, 치료 용량에서 주로 시냅스 후 알파 효과를 나타냄. 말초 혈관 수축을 통해 수축기 및 이완기 혈압을 상승시키고, 심박출량을 소폭 감소시키며, 순환 시간을 증가시킴. 평균 동맥압 상승에 따른 미주신경 활성화로 반사성 서맥이 발생할 수 있음.",
    "common_extra_effects": [
      "반사성 서맥 (reflex bradycardia)",
      "CNS 이상반응 (흥분, 불안)",
      "부정맥 (드물게)",
      "혈압 상승",
      "심박출량 감소",
      "신장·내장·폐·피부 혈관 수축",
      "관상동맥 혈류 증가",
      "자궁 수축 (임신 중)",
      "혈관외 유출 시 조직 괴사 및 탈락",
      "출혈 (말, 특히 노령마)"
    ],
    "dog_mechanism": "개에서는 심한 혈관 확장(예: 패혈성 쇼크) 시 유용할 수 있으나 일반적으로 드물게 사용됨.",
    "dog_extra_effects": [
      "반사성 서맥",
      "혈압 상승",
      "심박출량 감소"
    ],
    "cat_mechanism": "고양이에서 전신 혈관 확장(예: 내장 염증) 또는 심근 수축력 증가가 불리한 경우(예: 비대성 심근병증)에 혈압 상승 목적으로 사용 가능.",
    "cat_extra_effects": [
      "평균 동맥압 증가",
      "반사성 서맥",
      "고용량에서 심박출량 지수 및 일회박출량 지수 증가"
    ]
  },
  "species_notes": {
    "dog": "개에서는 패혈성 쇼크 등 심한 혈관 확장 상태에서 1–3 µg/kg/min IV CRI로 사용되며, 최대 10 µg/kg/min까지 사용된 사례가 있음. 충분한 수액 요법 후 사용해야 하며, 혈압 및 심박수 모니터링이 필수적임.",
    "cat": "고양이에서 1–2 µg/kg/min IV CRI로 사용됨. 비대성 심근병증 환자에서 심근 수축력 증가 없이 혈압을 올릴 수 있어 유용할 수 있음. 1 µg/kg/min에서 평균 동맥압이 유의하게 증가하였으며, 2 µg/kg/min에서는 심박출량 지수 및 일회박출량 지수도 증가함."
  },
