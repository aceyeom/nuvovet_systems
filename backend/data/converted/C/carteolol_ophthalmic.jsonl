  "effects_and_mechanisms": {
    "common_mechanism": "비선택적 베타-아드레날린 차단제(beta-1 및 beta-2). 내재적 교감신경 유사 활성(ISA) 보유. 섬모체 베타-2 수용체 차단을 통해 방수 생성을 감소시켜 안압(IOP)을 낮춤. cAMP 활성화 억제, Na+K+ATPase 활성 억제, 홍채 및 섬모체의 혈관 작용 기전 포함.",
    "common_extra_effects": [
      "점안 시 일시적 작열감, 따끔거림, 자극",
      "서맥 가능성 (점안 후 전신 흡수 시)",
      "기관지 경련 유발 가능 (천식 환자)",
      "저혈당 증상 마스킹",
      "갑상선기능항진증 증상 마스킹"
    ],
    "dog_mechanism": "점안 투여 시 섬모체 베타 수용체 차단으로 방수 생성 감소 → 안압 감소. 편측 녹내장 정상안에서 녹내장 발생 지연 효과 가능.",
    "dog_extra_effects": [
      "점안 시 일시적 자극",
      "심박수 감소 가능성"
    ],
    "cat_mechanism": "개와 동일한 기전으로 추정되나 고양이 특이 평가 없음.",
    "cat_extra_effects": [
      "점안 시 일시적 자극",
      "심박수 감소 가능성"
    ]
  },
  "species_notes": {
    "dog": "개에서 편측 녹내장의 정상안에 예방적으로 사용 시 녹내장 발생을 지연시킬 수 있음. 동물에서의 효능 평가는 공식적으로 수행되지 않았음. 천식 또는 심폐 질환이 있는 환자에서는 주의 사용.",
    "cat": "고양이에서의 효능 및 안전성 평가 데이터 없음. 점안 후 전신 흡수로 인한 심박수 감소 가능성을 배제할 수 없음. 심폐 질환 고양이에서 주의 사용."
  },
