  "effects_and_mechanisms": {
    "common_mechanism": "핵 수출 선택적 억제제(SINE)로서 CRM1(exportin-1/XPO1)을 가역적으로 억제하여 종양 억제 단백질(p53, RB1) 및 성장 조절 단백질(p21)의 세포핵 외 수송을 차단하고, 이를 통해 암세포의 세포자멸사를 유도함.",
    "common_extra_effects": [
      "식욕부진",
      "구토",
      "설사",
      "체중 감소",
      "기면",
      "다음증",
      "다뇨증",
      "간 효소 상승(ALP, ALT, AST)",
      "혈소판감소증",
      "림프구감소증",
      "빈혈",
      "백혈구감소증",
      "호중구감소증",
      "BUN 증가",
      "고칼슘혈증",
      "저염소혈증",
      "고인산혈증",
      "저단백혈증",
      "부분 트롬보플라스틴 시간 연장",
      "단백뇨",
      "혈뇨"
    ],
    "dog_mechanism": "CRM1 억제를 통해 종양 억제 단백질의 핵 내 축적을 유도하여 암세포 선택적 세포자멸사 유발. CRM1은 암세포에서 과발현 또는 돌연변이되어 있어 선택적 항암 효과를 나타냄.",
    "dog_extra_effects": [
      "발열",
