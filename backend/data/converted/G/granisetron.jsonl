  "effects_and_mechanisms": {
    "common_mechanism": "5-HT3(세로토닌3) 수용체를 선택적으로 차단하여 항구토 효과를 나타냄. 수용체는 CNS 화학수용체 유발대(CTZ), 미주신경 말단, 장신경계에 분포함.",
    "common_extra_effects": [
      "두통",
      "복통",
      "변비 또는 설사",
      "무력증(asthenia)",
      "졸음(somnolence)",
      "과민반응(드물게)",
      "부정맥(드물게)",
      "흉통(드물게)",
      "저혈압(드물게)"
    ],
    "dog_mechanism": "개에서는 장신경 및 미주신경 수용체가 구토 유발에 더 중요할 수 있음. 아포모르핀 유발 구토는 예방하지 못함.",
    "dog_extra_effects": [],
    "cat_mechanism": "고양이에서 항암화학요법 관련 구토는 주로 CTZ의 5-HT3 수용체 활성화에 의한 것으로 알려짐.",
    "cat_extra_effects": []
  },
  "species_notes": {
    "dog": "개에서 단회 0.02~0.4 mg/kg IV 투여가 효능을 보였으며, 0.1~0.5 mg/kg PO 또는 IV q12~24h 투여가 제안됨. IV 투여가 경구 투여보다 효과적일 수 있음. 아포모르핀 유발 구토에는 효과 없음. 수의학에서 사용 경험이 제한적임.",
    "cat": "고양이에서 1 mg/kg IM 1일 3회 투여가 보고됨. 항암화학요법 관련 구토 예방에 사용 가능. 수의학에서 사용 경험이 매우 제한적이며, 안전성 프로파일이 완전히 확립되지 않음."
  },
