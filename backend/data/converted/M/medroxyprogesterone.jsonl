  "effects_and_mechanisms": {
    "common_mechanism": "합성 프로게스틴으로서 자궁 내막을 분비기로 전환, 자궁 근층 비대 촉진, 자발적 자궁 수축 억제. 뇌하수체 성선자극호르몬 분비를 용량 의존적으로 억제. 항인슐린 효과 및 부신피질 억제 효과(ACTH 및 코르티솔 분비 억제). 항에스트로겐 효과 및 혈중 테스토스테론 감소.",
    "common_extra_effects": [
      "식욕 증가 및 체중 증가",
      "다뇨 및 다음증",
      "우울증 및 무기력",
      "성격 변화",
      "부신피질 억제",
      "유선 변화 (비대, 유즙 분비, 종양)",
      "당뇨병 유발",
      "갑상선 기능 저하증",
      "자궁축농증",
      "일시적 정자 형성 억제",
      "SC 주사 부위 영구적 탈모 또는 위축, 탈색소"
    ],
    "dog_mechanism": "개에서 당뇨병 환자에서 말단비대증 및 성장호르몬 증가가 보고됨. 사춘기 이전 사용 시 낭성 자궁 내막 증식증, 자궁축농증, 당뇨병 등 잠재적 자궁 또는 내분비 질환 유발 가능.",
    "dog_extra_effects": [
      "말단비대증 (당뇨병 환자에서)",
      "성장호르몬 증가",
      "낭성 자궁 내막 증식증 (사춘기 이전 사용 시)"
    ],
    "cat_mechanism": "고양이에서 사춘기 이전 사용 시 만성 중증 유선 비대 유발 가능. 행동 장애 치료에 사용되며 주사 후 약 30일간 효과 지속.",
    "cat_extra_effects": [
      "만성 중증 유선 비대 (사춘기 이전 사용 시)"
    ]
  },
