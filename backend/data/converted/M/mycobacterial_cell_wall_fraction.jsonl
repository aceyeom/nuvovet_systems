  "effects_and_mechanisms": {
    "common_mechanism": "Mycobacterium phlei 유래 세포벽 분획 에멀전으로, 대식세포 및 흉선 림프구를 활성화하여 항종양 사이토카인을 통해 간접적으로 종양 세포를 사멸시킴. 인터루킨-1(IL-1) 방출이 주요 매개체로 작용. 기능적 면역계가 필요함.",
    "common_extra_effects": [
      "일시적 발열",
      "기면(drowsiness)/우울감",
      "식욕감소",
      "주사 부위 국소 통증 및 염증",
      "종양 괴사 및 삼출(수 주간 지속 가능)",
      "아나필락시스/과민반응",
      "전신 염증 반응",
      "부종 및 권태감(초기 치료 후)"
    ],
    "dog_mechanism": "종양 내 주사를 통해 국소 면역 반응을 유도하여 혼합 유선 종양 및 유선 선암종에 항종양 효과를 나타냄.",
    "dog_extra_effects": [
      "주사 부위 통증",
      "종양 삼출 및 괴사",
      "발열",
      "식욕감소",
      "기면"
    ],
    "cat_mechanism": null,
    "cat_extra_effects": []
  },
  "species_notes": {
    "dog": "개에서 혼합 유선 종양 및 유선 선암종 치료에 USDA 승인된 생물제제(Immunocidin®)로 사용됨. 종양 내 주사만 허용되며, 20게이지 이하 바늘 사용. 최소 용량 1 mL이며 종양 크기에 따라 조절. 수술 2~4주 전 단회 투여 또는 1~3주 간격 반복 투여 가능. 4회 치료 후 반응 없으면 중단. 주사 전 에멀전을 충분히 혼합해야 하며, 혼합 직후 투여 필요. 통증 완화를 위해 마취제 또는 진통제 병용 가능.",
    "cat": "고양이에 대한 승인 또는 사용 데이터가 없음. 모노그래프에 고양이 관련 정보가 기재되어 있지 않음."
  },
  "precautions": {
    "dog": {
      "status": 1,
      "evidence": "과면역 질환 병력이 있는 개에서 주의 사용. 두드러기, 림프절염, 봉와직염, 농양 발생 시 즉시 투여 중단. 코르티코스테로이드 또는 면역억제제 투여 중인 환자는 치료 반응이 감소할 수 있음."
    },
