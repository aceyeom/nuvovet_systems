  "effects_and_mechanisms": {
    "common_mechanism": "H1 수용체 차단 항히스타민제로 항콜린성 특성을 가짐. 항구토, CNS 억제, 항경련, 국소마취 효과를 나타냄. 항구토 및 멀미 방지 효과는 중추 항콜린성 및 CNS 억제 활성을 통해 화학수용체 유발대(CTZ)에서 매개되는 것으로 추정됨.",
    "common_extra_effects": [
      "진정(졸음)",
      "구강 건조",
      "안구 건조",
      "빈맥",
      "역설적 CNS 자극",
      "요저류",
      "변비"
    ],
    "dog_mechanism": null,
    "dog_extra_effects": [
