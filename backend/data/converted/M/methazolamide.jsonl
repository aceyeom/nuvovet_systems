  "effects_and_mechanisms": {
    "common_mechanism": "탄산탈수효소(carbonic anhydrase)의 비경쟁적, 가역적 억제제. 이산화탄소로부터 수소이온 및 중탄산이온 생성을 감소시켜 방수 생성 감소, 안압 저하, 신세뇨관에서 나트륨·칼륨·중탄산염 분비 증가, 소변 알칼리화 및 이뇨 효과를 나타냄.",
    "common_extra_effects": [
      "구토, 설사, 식욕부진 등 위장관 장애",
      "대사성 산증 (과호흡 동반)",
      "진정, 우울, 방향감각 상실, 흥분 등 CNS 효과",
      "저칼륨혈증",
      "골수 억제, 혈소판 감소증",
      "결정뇨, 배뇨통, 신산통, 다뇨, 다음",
      "고혈당증",
      "저나트륨혈증",
      "고요산혈증",
      "간부전",
      "발진 등 피부 반응",
      "과민반응",
      "전해질 불균형으로 인한 허약감 또는 심장 부정맥"
    ],
    "dog_mechanism": null,
    "dog_extra_effects": [],
    "cat_mechanism": null,
    "cat_extra_effects": [
      "고양이는 개보다 부작용에 더 취약한 것으로 알려져 있음"
    ]
  },
  "species_notes": {
    "dog": "개에서 개방각 녹내장의 내과적 치료에 오프라벨로 사용됨. 2~5 mg/kg을 하루 2~3회 경구 투여. 안압 측정, 혈청 전해질, CBC 정기 모니터링 필요. 위장관 부작용 발생 시 음식과 함께 투여.",
    "cat": "고양이에서 개방각 녹내장의 내과적 치료에 오프라벨로 사용됨. 1~4 mg/kg을 하루 2~3회 경구 투여. 고양이는 개보다 부작용에 더 취약하므로 더욱 주의 깊은 모니터링이 필요함."
  },
  "precautions": {
    "dog": {
      "status": 1,
      "evidence": "간질환, 신부전, 전해질 불균형, 저칼륨혈증, 저나트륨혈증, 폐질환 환자에서 금기. 장기 사용 시 CBC 및 전해질 정기 모니터링 필요. 설폰아미드 유도체로 중증 과민반응 가능성 있음."
    },
    "cat": {
      "status": 1,
      "evidence": "고양이는 개보다 부작용에 더 취약함. 더욱 주의 깊은 모니터링과 낮은 용량 범위(1~4 mg/kg) 사용 권장. 동일한 금기사항 적용."
    }
  },
