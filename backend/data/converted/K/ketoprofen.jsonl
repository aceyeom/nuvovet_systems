  "effects_and_mechanisms": {
    "common_mechanism": "COX-1 및 COX-2의 비선택적·가역적 억제를 통해 아라키돈산에서 프로스타글란딘 전구체(엔도퍼옥사이드)로의 전환을 차단하여 조직 내 프로스타글란딘 합성을 억제함. 리폭시게나제 억제 활성도 주장되나 in vitro 연구에서 확인되지 않음. 라세믹 혼합물로 S(+) 에난티오머가 항프로스타글란딘 활성 및 독성과 관련, R(-) 에난티오머가 진통 효과와 관련됨.",
    "common_extra_effects": [
      "위장관 궤양 및 점막 손상",
      "구토",
      "식욕부진",
      "신장 유두 괴사",
      "경미한 간염",
      "혈소판 응집 억제",
      "출혈 위험 증가"
    ],
    "dog_mechanism": "COX-1/COX-2 비선택적 억제; 개에서 수술 전후 혈소판 응집 감소 보고",
    "dog_extra_effects": [
      "구토",
      "식욕부진",
      "위장관 궤양",
      "크레아티닌 청소율 감소 (고용량 시)",
      "혈소판 응집 감소"
    ],
    "cat_mechanism": "COX-1/COX-2 비선택적 억제; S(+) 에난티오머가 COX 억제 담당; SC 투여 후 혈청 PGE2 및 트롬복산 B2 유의하게 감소",
