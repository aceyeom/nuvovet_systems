  "effects_and_mechanisms": {
    "common_mechanism": "페난트렌계 합성 오피오이드 수용체 작용제-길항제. 카파 수용체 작용(주요 진통 효과), 뮤 수용체 부분 길항, 델타 수용체 결합. 카파 수용체 활성화를 통해 진통 효과를 나타냄.",
    "common_extra_effects": [
      "호흡억제 (드물지만 가능)",
      "흥분 (고용량)",
      "불쾌감 (dysphoria)",
      "구토",
      "서맥",
      "진정"
    ],
    "dog_mechanism": "카파 수용체 작용을 통한 진통. 개에서 혈장 히스타민을 증가시키지 않음. 경막외 투여 시 이소플루란의 MAC을 감소시키고 난소자궁절제술 후 진통 제공.",
    "dog_extra_effects": [
      "흥분 (고용량)",
      "불쾌감",
      "구토",
      "서맥",
      "호흡억제 (드물)"
    ],
    "cat_mechanism": "카파 수용체 작용을 통한 진통. 고양이 특이적 기전 데이터는 제한적이나 소동물에서 유사하게 적용됨.",
    "cat_extra_effects": [
      "흥분 (고용량)",
      "불쾌감",
      "구토",
      "서맥",
      "호흡억제 (드물)"
    ]
