  "effects_and_mechanisms": {
    "common_mechanism": "탄산탈수효소(carbonic anhydrase) 비경쟁적·가역적 억제를 통해 탄산으로부터 수소이온 및 중탄산이온 생성을 감소시킴. 안구 내에서는 방수 생성 감소로 안압 저하, 신장에서는 나트륨·칼륨·중탄산이온의 세뇨관 분비 증가로 이뇨 효과 발휘.",
    "common_extra_effects": [
      "GI 장애 (오심, 구토, 설사, 식욕부진)",
      "CNS 효과 (진정, 우울, 허약, 흥분, 이상감각)",
      "혈액학적 효과 (골수 억제)",
      "신장 효과 (결정뇨, 배뇨통, 신산통, 다뇨)",
      "저칼륨혈증",
      "고염소혈증",
      "고혈당증",
      "저나트륨혈증",
      "고요산혈증",
      "간부전",
      "피부 반응 (발진)",
      "과민반응 (Stevens-Johnson 증후군, 독성 표피 괴사용해)"
    ],
    "dog_mechanism": "탄산탈수효소 억제를 통한 방수 생성 감소(녹내장 치료) 및 이뇨 효과(대사성 알칼리증 치료). 항경련 활성도 있으나 기전 불명확.",
    "dog_extra_effects": [
      "고용량 IV 투여 후 산증 발생",
      "경미한 진전(1시간 내 자연 소실)"
    ],
    "cat_mechanism": "탄산탈수효소 억제를 통한 방수 생성 감소(녹내장 치료). 마취된 고양이에서 저산소성 환기 반응 억제 보고(경동맥체 또는 I형 세포에 대한 직접 효과로 추정).",
    "cat_extra_effects": [
      "저산소성 환기 반응 억제 가능성"
    ]
