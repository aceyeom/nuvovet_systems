  "effects_and_mechanisms": {
    "common_mechanism": "플라스미노겐 활성화 물질 억제 및 항플라스민 활성을 통해 섬유소용해를 억제하는 합성 단아미노 카르복실산. 항프로테아제 활성을 통해 마이엘린을 손상시키는 염증 효소 활성화를 감소시키는 것으로 추정됨.",
    "common_extra_effects": [
      "GI 자극(약 1%의 개에서 경구 투여 시)",
      "고칼륨혈증(특히 신기능 저하 환자)",
      "빠른 IV 투여 시 저혈압",
      "빠른 IV 투여 시 서맥",
      "근염 및 골격근 약화(인체에서 드물게)",
      "근섬유 괴사(인체에서 드물게)"
    ],
    "dog_mechanism": "개에서 섬유소용해를 완전히 억제하기 위해 필요한 혈장 농도(511.7 µg/mL)는 인체(122 µg/mL)보다 훨씬 높음.",
    "dog_extra_effects": [
      "심내막하 출혈",
      "심근 지방 변성",
      "과용량 시 강직-간대 발작"
    ],
    "cat_mechanism": null,
    "cat_extra_effects": []
  },
  "species_notes": {
    "dog": "개에서 섬유소용해 억제에 필요한 혈장 농도가 인체보다 약 4배 높으므로 인체 용량 외삽 시 혈중 농도가 최적 이하일 수 있음. 그레이하운드 등 시각하운드에서 수술 후 출혈 예방에 주로 사용됨. 퇴행성 척수병증 치료 목적 사용은 효능이 불확실하며 모든 연구 대상 개에서 신경학적 증상이 악화됨. 장기 치료 시 크레아틴 키나아제 모니터링 필요.",
    "cat": "고양이에서의 용량, 안전성, 효능에 대한 데이터가 없음. 사용 시 극도의 주의가 필요하며 수의사의 면밀한 감독 하에 이익-위험 평가 후 결정해야 함."
  },
  "precautions": {
    "dog": {
      "status": 1,
      "evidence": "DIC 환자에서 절대 금기. 신장·심장·간 질환 환자에서 이익이 위험을 상회할 때만 사용. 빠른 IV 투여 금지. 과섬유소용해의 실험실적 확인(TEG 등) 없이 투여 금지. 개에서 심내막하 출혈 및 심근 지방 변성 보고됨."
    },
    "cat": {
      "status": 1,
      "evidence": "고양이에서 안전성 및 효능 데이터 없음. 사용 시 주의 필요."
    }
  },
  "storage_and_forms": {
    "storage": "실온(20°C–25°C) 보관. 액체 제제 동결 금지. 생리식염수 또는 5% 포도당 희석액(10 및 100 mg/mL)은 4°C 및 23°C에서 7일간 98% 역가 유지. 알데히드 또는 알데히드성 당류 존재 시 변색 발생.",
    "forms": [
      "경구 정제: 500 mg, 1000 mg (Amicar®)",
      "경구 시럽: 250 mg/mL, 237 mL (Amicar®)",
      "주사제: 250 mg/mL, 20 mL 바이알 (generic)"
    ]
  },
  "section_1_2_10": {
    "highlights": "아미노카프로산은 과섬유소용해 억제제로, 그레이하운드 등 시각하운드의 수술 후 출혈 예방 및 과섬유소용해에 의한 출혈 치료에 주로 사용됩니다. 수의학적으로 승인된 제품은 없으며 모두 적응증 외 사용입니다. DIC 환자에서는 절대 금기이며, 반드시 과섬유소용해의 실험실적 확인(TEG 등) 후 투여해야 합니다. 개에서 인체보다 약 4배 높은 혈장 농도가 필요하므로 인체 용량 외삽 시 주의가 필요합니다. 빠른 IV 투여는 저혈압 및 서맥을 유발할 수 있습니다.",
    "indications": "【승인 적응증】없음(수의학적 승인 제품 없음). 【적응증 외 사용】① 그레이하운드/시각하운드 수술 후 지연성 출혈 예방 ② 과섬유소용해에 의한 출혈 치료 ③ 우심방 종괴에 의한 심낭 삼출(효능 불확실) ④ 활동성 출혈(종양성 질환, 수술 후 출혈 등) ⑤ 퇴행성 척수병증 보조 치료(효능 매우 불확실, 권장하지 않음) ⑥ 말: 인두낭 출혈 항섬유소용해 치료.",
