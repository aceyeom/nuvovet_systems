  "effects_and_mechanisms": {
    "common_mechanism": "염화암모늄은 체내에서 염화물 이온과 암모늄 이온으로 해리됨. 암모늄 양이온은 간에서 요소로 전환되며 수소 이온이 방출됨. 이 수소 이온은 중탄산염과 결합하여 물과 이산화탄소를 형성함. 세포외액에서 염화물 이온은 고정 염기와 결합하여 체내 알칼리 저장량을 감소시킴. 결과적으로 혈청 중탄산염 수치 감소 및 혈액·소변 pH 저하가 나타남.",
    "common_extra_effects": [
      "대사성 산증",
      "위장 자극, 오심, 구토",
      "칼슘 옥살레이트 요석 형성 위험 증가",
      "과다복용 시: 오심, 구토, 과도한 갈증, 과호흡, 서맥, 부정맥, 진행성 CNS 억제",
      "저칼륨혈증"
    ],
    "dog_mechanism": null,
    "dog_extra_effects": [],
    "cat_mechanism": null,
    "cat_extra_effects": []
  },
  "species_notes": {
    "dog": "개에서 요산성화, 독성 물질(스트리크닌 등) 신장 배설 촉진, 특정 항균제 효능 강화, 간기능 검사(암모니아 내성 검사)에 사용됨. 모두 허가 외 사용임. 투여 전 기저 암모니아 수치 확인 필수.",
    "cat": "고양이에서 요산성화 및 암모니아 내성 검사에 사용됨(허가 외). 산성화 상업용 고양이 사료로 스트루바이트 요석 형성을 최소화할 수 있으며, 해당 식이요법이 불가능한 경우 염화암모늄을 고려할 수 있음."
  },
  "precautions": {
    "dog": {
      "status": 1,
      "evidence": "간질환, 요독증, 요산염/옥살레이트 결석, 호흡성 산증 환자에서 금기. 폐기능 부전 또는 심장 부종 환자에서 주의 사용. 대사성 산증 모니터링 필요."
    },
    "cat": {
