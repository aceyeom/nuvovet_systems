  "effects_and_mechanisms": {
    "common_mechanism": "알파-1 및 알파-2 아드레날린 수용체 경쟁적 차단제. 혈관 평활근을 직접 이완시켜 말초혈관 확장 및 총 말초저항 감소. 부교감신경 유사 또는 히스타민 H2 작용제 효과를 통해 위장관 분비 및 운동성 자극.",
    "common_extra_effects": [
      "일시적 빈맥",
      "말초혈관확장(발한, 점막 충혈)",
      "입술 통각과민(핥기, 입술 뒤집기)",
      "기모(piloerection)",
      "맑은 눈물 및 비루",
      "근육 연축(fasciculations)",
      "불안/흥분",
      "위장관 과운동",
      "저혈압",
      "심실 부정맥(과용량 시)"
    ],
    "dog_mechanism": "알파-2 아드레날린 수용체 차단을 통한 자일라진 효과 역전. 개에서의 구체적 기전 데이터는 제한적.",
    "dog_extra_effects": [
      "빈맥",
      "저혈압",
      "위장관 과운동"
    ],
    "cat_mechanism": "알파-2 아드레날린 수용체 차단을 통한 자일라진 효과 역전. 고양이에서의 구체적 기전 데이터는 제한적.",
    "cat_extra_effects": [
