  "effects_and_mechanisms": {
    "common_mechanism": "헨레 고리 상행각에서 1Na+/1K+/2Cl- 공동수송체의 염소 결합 부위를 차단하여 나트륨, 염소, 수분의 재흡수를 억제하는 루프 이뇨제. 푸로세미드보다 약 10~20배 강력하며 이뇨 효과가 약 12시간 지속됨.",
    "common_extra_effects": [
      "구토",
      "설사",
      "식욕부진",
      "다뇨",
      "신장 수치 상승",
      "신부전",
      "저칼륨혈증",
      "저나트륨혈증",
      "저칼슘혈증",
      "저마그네슘혈증",
      "탈수",
      "저혈압",
      "빈혈",
      "백혈구 감소증",
      "허약감",
      "불안",
      "이독성(고용량)"
    ],
    "dog_mechanism": "개에서 나트륨 대비 칼륨 배설 비율이 20:1로 푸로세미드보다 약 2배 높음. 알도스테론 수치를 증가시키고 수용체 결합 알도스테론을 억제하는 효과가 있음. 건강한 개에서 14일 후 푸로세미드에 대한 이뇨 저항성이 발생하였으나 토르세미드에서는 발생하지 않음.",
    "dog_extra_effects": [
      "구강 점막 건조",
      "음수량 증가",
      "소변 pH 증가",
      "소변 비중 감소",
      "혈청 알도스테론 농도 증가",
      "BUN 및 혈장 크레아티닌 증가"
    ],
    "cat_mechanism": "고양이에서 칼륨 배설 효과는 푸로세미드와 유사. 최대 이뇨는 투여 후 약 4시간에 발생하며 12시간 지속됨.",
    "cat_extra_effects": [
      "전해질 불균형",
      "다뇨"
    ]
  },
  "species_notes": {
    "dog": "개에서 토르세미드는 MMVD C~D 단계의 심부전에서 푸로세미드에 반응하지 않는 경우 대안으로 사용됨. 복수의 임상 연구에서 푸로세미드에 비해 비열등성이 확인되었으며, 심장 사망 위험을 64% 감소시키는 효과가 보고됨. 그러나 부작용 발생 빈도가 더 높을 수 있으므로 신기능 및 전해질 모니터링이 필수적임. 초기 용량은 푸로세미드 총 1일 용량의 5~10%에서 시작.",
    "cat": "고양이에서 소규모 후향적 연구에서 자발성 CHF의 1차 및 2차 치료로 내약성이 확인됨. 고양이에서의 데이터는 제한적이므로 신중한 모니터링이 필요함. 최대 이뇨는 투여 후 약 4시간에 발생하며 12시간 지속됨."
  },
